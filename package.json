{
	"name": "generic-midi",
	"version": "2.1.1",
	"main": "dist/main.js",
	"type": "module",
	"scripts": {
		"postinstall": "husky",
		"format": "prettier -w .",
		"package": "yarn build && companion-module-build",
		"package:dev": "yarn build && companion-module-build --dev",
		"build": "rimraf dist && yarn build:main",
		"build:main": "tsc -p tsconfig.build.json",
		"dev": "tsc -p tsconfig.build.json --watch",
		"lint:raw": "eslint",
		"lint": "yarn lint:raw ."
	},
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/bitfocus/companion-module-generic-midi.git"
	},
	"engines": {
		"node": ">=22.0.0"
	},
	"dependencies": {
		"@companion-module/base": "^2.0.0",
		"@julusian/midi": "^3.6.1",
		"rimraf": "^6.1.0"
	},
	"devDependencies": {
		"@companion-module/tools": "^3.0.0",
		"@types/node": "^22.0.0",
		"eslint": "~9.14.0",
		"husky": "^9.1.0",
		"lint-staged": "^17.0.0",
		"prettier": "^3.8.0",
		"typescript": "^6.0.0",
		"typescript-eslint": "^8.60.0"
	},
	"prettier": "@companion-module/tools/.prettierrc.json",
	"lint-staged": {
		"*.{css,json,md,scss}": [
			"prettier --write"
		],
		"*.{ts,tsx,js,jsx}": [
			"yarn lint:raw --fix"
		]
	},
	"packageManager": "yarn@4.4.1"
}
